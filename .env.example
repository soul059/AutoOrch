# AutoOrch Environment Configuration

# Database
DATABASE_URL=postgresql://autoorch:autoorch_dev_password@localhost:5432/autoorch

# API Server
PORT=3001
WS_PORT=3002
NODE_ENV=development

# Authentication — comma-separated list of valid API keys
# If empty/unset, authentication is disabled (dev mode only)
# API_KEYS=your-secret-key-1,your-secret-key-2

# Encryption key for credential storage (32-byte hex = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, credentials are base64-encoded (dev mode only — NOT SECURE)
# APP_ENCRYPTION_KEY=your-64-char-hex-key

# SSRF Protection — allow local providers (Ollama, LMStudio)
ALLOW_LOCAL_PROVIDERS=true

# CORS — allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Cloud Providers (add your API keys here)
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Budget Defaults
DEFAULT_MAX_TOKENS=100000
DEFAULT_MAX_COST_USD=10.0
DEFAULT_MAX_LOOP_ITERATIONS=50
